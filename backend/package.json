{
  "name": "backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint 'src/**/*.ts'",
    "test": "jest",
    "test:integration": "jest --testPathPattern=integration",
    "migrate": "ts-node src/migrate.ts",
    "migrate:dry-run": "ts-node src/migrate.ts --dry-run"
  },
  "dependencies": {
    "dotenv": "16.4.5",
    "express": "4.19.2",
    "pg": "8.12.0"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/jest": "29.5.12",
    "@types/node": "20.14.10",
    "@types/pg": "8.11.6",
    "@typescript-eslint/eslint-plugin": "7.16.0",
    "@typescript-eslint/parser": "7.16.0",
    "eslint": "8.57.0",
    "jest": "29.7.0",
    "ts-jest": "29.2.2",
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0",
    "typescript": "5.5.4"
  }
}
